{
  "name": "sitepoemas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node --env-file=.env.local scripts/generate-sitemap.js || node scripts/generate-sitemap.js",
    "rss": "node --env-file=.env.local scripts/generate-rss.js || node scripts/generate-rss.js",
    "build": "npm run sitemap && npm run rss && vite build && (node --env-file=.env.local scripts/prerender.js || node scripts/prerender.js)",
    "deploy": "npm run build && gh-pages -d dist",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "fast-xml-parser": "^5.7.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@zumer/snapdom": "^2.12.9",
    "resend": "^6.16.0"
  }
}
