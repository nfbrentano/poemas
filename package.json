{
  "name": "sitepoemas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node --env-file=.env.local scripts/generate-sitemap.js || node scripts/generate-sitemap.js",
    "rss": "node --env-file=.env.local scripts/generate-rss.js || node scripts/generate-rss.js",
    "build": "npm run sitemap && npm run rss && vite build",
    "deploy": "npm run build && gh-pages -d dist",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "fast-xml-parser": "^5.7.1",
    "gh-pages": "^6.3.0",
    "vite": "^8.0.10",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "html2canvas": "^1.4.1"
  }
}
